# ─── Env / config ───────────────────────────────────────────────────────────

def load_env():
    base_path = getattr(sys, "_MEIPASS", None) or os.path.abspath(".")
    env_path = os.path.join(base_path, ".env")
    load_dotenv(env_path)

load_env()
AIOT03_DEV = os.getenv("WEB_SERVICES")
if not AIOT03_DEV:
    raise ValueError("WEB_SERVICES not set in .env")

ctk.set_appearance_mode("dark")
ctk.set_default_color_theme("blue")


# ─── DB ──────────────────────────────────────────────────────────────────────

def connect_db1():
    return pyodbc.connect(
        f"DRIVER={{{os.getenv('DB2_DRIVER')}}};"
        f"SERVER={os.getenv('DB2_SERVER')};"
        f"DATABASE={os.getenv('DB2_DATABASE')};"
        f"Trusted_Connection={os.getenv('DB2_TRUSTED')};"
    )


def resource_path(relative_path):
    base_path = getattr(sys, "_MEIPASS", None) or os.path.abspath(".")
    return os.path.join(base_path, relative_path)


# ─── Data helpers ────────────────────────────────────────────────────────────

def fetch_pool_list():
    try:
        conn = connect_db1()
        df = pd.read_sql("SELECT Name FROM JOB_POOL WHERE Name LIKE '%MI%'", conn)
        conn.close()
        return df["Name"].dropna().tolist()
    except Exception as e:
        print("fetch_pool_list error:", e)
        return []


def fetch_sync_queue_list(pool, from_dt, to_dt):
    try:
        conn = connect_db1()
        cursor = conn.cursor()
        with open(resource_path("sql/PROD_SQ.sql"), "r") as f:
            query = f.read()
        cursor.execute(query, pool, from_dt, to_dt)
        rows = cursor.fetchall()
        conn.close()
        return [r[0] for r in rows] if rows else ["No Data Found"]
    except Exception as e:
        print("fetch_sync_queue_list error:", e)
        return ["Error Loading"]


# ─── DateTimePicker ───────────────────────────────────────────────────────────

class DateTimePicker(ctk.CTkFrame):
    def __init__(self, master, label, default_time=("00", "00", "00")):
        super().__init__(master)

        ctk.CTkLabel(self, text=label, width=80).pack(side="left", padx=5)

        self.date = DateEntry(self, width=12, date_pattern="yyyy-mm-dd")
        self.date.pack(side="left", padx=5)

        self.hour = ctk.CTkComboBox(self, width=60, values=[f"{i:02d}" for i in range(24)])
        self.hour.set(default_time[0])
        self.hour.pack(side="left", padx=(10, 2))

        ctk.CTkLabel(self, text=":").pack(side="left")

        self.minute = ctk.CTkComboBox(self, width=60, values=[f"{i:02d}" for i in range(60)])
        self.minute.set(default_time[1])
        self.minute.pack(side="left", padx=2)

        ctk.CTkLabel(self, text=":").pack(side="left")

        self.second = ctk.CTkComboBox(self, width=60, values=[f"{i:02d}" for i in range(60)])
        self.second.set(default_time[2])
        self.second.pack(side="left", padx=2)

        ctk.CTkLabel(self, text="(CET)", text_color="gray").pack(side="left", padx=10)

    def get_cet_datetime(self):
        """Return a CET-aware datetime. Uses is_dst=False to handle DST ambiguity safely."""
        try:
            dt = datetime.strptime(
                f"{self.date.get()} {self.hour.get()}:{self.minute.get()}:{self.second.get()}",
                "%Y-%m-%d %H:%M:%S",
            )
            cet = pytz.timezone("Europe/Berlin")
            # FIX: is_dst=False avoids AmbiguousTimeError during clock-back transitions
            return cet.localize(dt, is_dst=False)
        except Exception as e:
            print("DateTimePicker.get_cet_datetime error:", e)
            return None


