        self.progress_count_label.pack_forget()

        # ── Sync queue auto-refresh ───────────────────────────────────────────
        def refresh_sync_queue(*_):
            pool = self.pool_var.get()
            if pool in ("", "Select Pool", None):
                self.sync.configure(values=["Select Down"])
                self.sync.set("Select Down")
                return
            f_dt = self.from_dt.get_cet_datetime()
            t_dt = self.to_dt.get_cet_datetime()
            values = fetch_sync_queue_list(pool, f_dt, t_dt)
            self.sync.configure(values=values)
            if values:
                self.sync.set(values[0])

        self.pool_var.trace_add("write", refresh_sync_queue)
        self.from_dt.date.bind("<<DateEntrySelected>>", refresh_sync_queue)
        self.to_dt.date.bind("<<DateEntrySelected>>", refresh_sync_queue)

        # FIX: also refresh when hour/minute/second change
        for picker in (self.from_dt, self.to_dt):
            picker.hour.configure(command=lambda _v: refresh_sync_queue())
            picker.minute.configure(command=lambda _v: refresh_sync_queue())
            picker.second.configure(command=lambda _v: refresh_sync_queue())

    # ─── Thread launchers ────────────────────────────────────────────────────
    # Rule: ZERO Tkinter widget reads inside background threads.
    # Every value that the worker needs is read HERE on the main thread and
    # passed as a plain Python value.  The worker never touches self.pool_var,
    # self.sync_var, self.from_dt, self.to_dt, or self.tree directly.

    def _snapshot_filter(self) -> dict:
        """Read all filter widgets NOW (main thread) and return plain values."""
        return {
            "pool":       self.pool_var.get(),
            "sync_queue": self.sync_var.get(),
            "sync_pat":   f"%{self.sync_var.get()}%",
            "from_dt":    self.from_dt.get_cet_datetime(),
            "to_dt":      self.to_dt.get_cet_datetime(),
        }

    def _thread_search(self):
        f = self._snapshot_filter()
        threading.Thread(target=self._search, args=(f,), daemon=True).start()

    def _thread_reprocess_selected(self):
        selected_items = self.tree.selection()
        if not selected_items:
            messagebox.showwarning("Warning", "Select at least one Serial Number.")
            return
        serials = [self.tree.item(i, "values")[0] for i in selected_items]
        f = self._snapshot_filter()
        self._set_processing(True, total=len(serials))
        threading.Thread(
            target=self._reprocess_worker, args=(serials, f, False), daemon=True
        ).start()

    def _thread_reprocess_all(self):
        serials = [self.tree.item(i, "values")[0] for i in self.tree.get_children()]
        if not serials:
            messagebox.showwarning("Warning", "No records to reprocess.")
            return
        f = self._snapshot_filter()
        self._set_processing(True, total=len(serials))
        threading.Thread(
            target=self._reprocess_worker, args=(serials, f, True), daemon=True
        ).start()

    # ─── Thread-safe UI helpers ──────────────────────────────────────────────

    def log(self, message: str):
        ts = datetime.now().strftime("%H:%M:%S")
        line = f"[{ts}] {message}\n"
        self.after(0, lambda: (self.log_text.insert("end", line), self.log_text.see("end")))

    def _show_error(self, title: str, msg: str):
        self.after(0, lambda: messagebox.showerror(title, msg))

    def _show_warning(self, title: str, msg: str):
        self.after(0, lambda: messagebox.showwarning(title, msg))

    def _clear_log(self):
        self.after(0, lambda: self.log_text.delete("1.0", "end"))

    def _clear_tree(self):
        self.after(0, lambda: [self.tree.delete(i) for i in self.tree.get_children()])

    def _insert_tree_row(self, values: tuple):
        self.after(0, lambda v=values: self.tree.insert("", "end", values=v))

    # ─── Processing state helpers (main thread only via self.after) ──────────

    def _set_processing(self, active: bool, total: int = 0):
        """
        MUST run on the main thread (call directly from launchers,
        or via self.after(0, ...) from background threads).

        active=True  : disable buttons, show + reset progress widgets.
        active=False : re-enable buttons, mark bar complete, auto-hide after 3 s.
        """
        if active:
            for btn in (self.btn_reprocess_selected, self.btn_reprocess_all,
                        self.btn_view, self.btn_export):
                btn.configure(state="disabled")
            self._total_serials = total          # stored for flush callbacks
            self.progress_bar.set(0)
            self.progress_label.configure(text=f"Processing 0 / {total}")
            self.progress_count_label.configure(text="")
            # Show widgets (pack_forget was called at init; pack re-adds them)
            self.progress_label.pack(pady=(8, 0))
            self.progress_bar.pack(pady=(4, 0))
            self.progress_count_label.pack(pady=(2, 4))
        else:
            for btn in (self.btn_reprocess_selected, self.btn_reprocess_all,
                        self.btn_view, self.btn_export):
                btn.configure(state="normal")
            self.progress_bar.set(1)
            self.progress_label.configure(text="Done ✓")
            self.progress_count_label.configure(text="")
            # Auto-hide after 3 s so the panel doesn't stay cluttered
            self.after(3000, self._hide_progress)

    def _hide_progress(self):
        """Remove progress widgets from layout (main thread)."""
        self.progress_label.pack_forget()
        self.progress_bar.pack_forget()
        self.progress_count_label.pack_forget()

    # ─── Search ──────────────────────────────────────────────────────────────

    def _search(self, f: dict):
        """Background thread. f = pre-snapshotted filter dict."""
        self._clear_log()
        self.log("Search started…")
        self._clear_tree()
        self.processed.clear()

        conn = cursor = None
        try:
            conn = connect_db1()
            cursor = conn.cursor()

            with open(resource_path("sql/FailedFG.sql"), "r") as fh:
                query = fh.read()

            cursor.execute(query, (f["pool"], f["sync_pat"], f["from_dt"], f["to_dt"]))
            rows = cursor.fetchall()

            if not rows:
                self.log("No failed FG Serial Numbers found.")
                return

            for row in rows:
                serial  = row.fgserialnumber if hasattr(row, "fgserialnumber") else row[0]
                fail_dt = row.FinishedOn     if hasattr(row, "FinishedOn")     else row[1]
                reason  = row.Info           if hasattr(row, "Info")           else row[2]
                if fail_dt:
                    fail_dt = fail_dt.strftime("%Y-%m-%d %H:%M:%S")
                self._insert_tree_row((serial, fail_dt, reason))

            self.log(f"Loaded {len(rows)} record(s).")

        except Exception as e:
            self.log(f"Error: {e}")
            self._show_error("Search Error", str(e))
        finally:
            if cursor: cursor.close()
            if conn:   conn.close()

    # ─── Process single FG (pure worker — no Tkinter reads) ──────────────────

    def _process_fg(self, fgserialnumber: str, f: dict, cursor, session: requests.Session, log_fn=None):
        """
        Background thread only.  All filter values come from f (plain dict).

        log_fn — optional callable(str) for buffered logging from _reprocess_worker.
                 Falls back to self.log (direct after() call) when called standalone.
        """
        _log = log_fn if log_fn is not None else self.log

        if not fgserialnumber:
            _log("Invalid Serial Number — skipping.")
            return

        _log(f"Processing: {fgserialnumber}")

        try:
            with open(resource_path("sql/AIOT03_BasedOnFG.sql"), "r", encoding="utf-8") as fh:
                query = fh.read()

            cursor.execute(
                query,
                f["pool"], f["sync_pat"], f["from_dt"], f["to_dt"], fgserialnumber
            )
            rows = cursor.fetchall()

            if not rows:
                _log(f"No data found for {fgserialnumber}")
                return

            success_count = fail_count = 0

            for row in rows:
                msg = row[0]
                payload = {
                    "Inputs": {"IncomingMessage": msg},
                    "ExecutionMode": 1,
                    "Retries": 1,
                    "SleepTime": 100,
                    "SynchronousQueue": "",
                    "Timeout": 100,
                }
                try:
                    response = session.post(AIOT03_DEV, json=payload, verify=False, timeout=30)
                    try:
                        resp_json = response.json()
                    except Exception:
                        resp_json = response.text

                    if response.status_code in (200, 201):
                        fail_code = None
                        if isinstance(resp_json, dict):
                            fail_code = resp_json.get("FailDictCode", None)

                        if fail_code == "":
                            success_count += 1
                            _log(f"{fgserialnumber} → Success (FailDictCode: empty)")
                            self.result_data[fgserialnumber] = {
                                "status": "Success",
                                "response": str(resp_json),
                                "tag": "success",
                            }
                        else:
                            fail_count += 1
                            code_display = fail_code if fail_code is not None else "key missing"
                            _log(f"{fgserialnumber} → Failed (FailDictCode: {code_display})")
                            self.result_data[fgserialnumber] = {
                                "status": "Failed",
                                "response": str(resp_json),
                                "tag": "failed",
                            }
                    else:
                        fail_count += 1
                        _log(f"{fgserialnumber} → Failed (HTTP {response.status_code})")
                        self.result_data[fgserialnumber] = {
                            "status": "Failed",
                            "response": f"HTTP {response.status_code} | {resp_json}",
                            "tag": "failed",
                        }
                except Exception as req_err:
                    fail_count += 1
                    _log(f"{fgserialnumber} → Request error: {req_err}")
                    self.result_data[fgserialnumber] = {
                        "status": "Error",
                        "response": str(req_err),
                        "tag": "failed",
                    }

            _log(f"{fgserialnumber} done — Success: {success_count}, Failed: {fail_count}")

        except Exception as e:
            _log(f"Error processing {fgserialnumber}: {e}")

    # ─── Unified reprocess worker ─────────────────────────────────────────────

    # Flush accumulated log lines to the UI every this many serials.
    # Keeps the main-thread event queue from being flooded with 1000s of after() calls.
    _LOG_FLUSH_EVERY = 10

    def _reprocess_worker(self, serials: list, f: dict, advance_queue: bool):
        """
        Background thread.

        serials        — pre-snapshotted serial numbers.
        f              — pre-snapshotted filter dict (no Tkinter reads needed).
        advance_queue  — if True (Reprocess All), auto-advance to the next sync
                         queue once all items are done, then trigger a new search.

        UI update strategy (prevents "Not Responding" on large batches):
          • Log lines are accumulated in a local list and flushed to the
            CTkTextbox in a SINGLE self.after() call every LOG_FLUSH_EVERY items.
          • Progress bar is updated in the same batched after() call.
          • Buttons are disabled for the duration and re-enabled on completion.
        """
        self._clear_log()

        total        = len(serials)
        done         = 0
        processed_any = False
        log_buffer: list[str] = []

        def _flush(final: bool = False):
            """
            Drain log_buffer + update progress bar in ONE self.after() call.
            Called every _LOG_FLUSH_EVERY serials — never once per serial —
            so the Tkinter event queue stays shallow even for 1000+ items.
            """
            if not log_buffer and not final:
                return
            lines = "".join(log_buffer)
            log_buffer.clear()
            _done, _total = done, total   # capture current values for the closure

            def _ui_update():
                if lines:
                    self.log_text.insert("end", lines)
                    self.log_text.see("end")
                fraction = _done / _total if _total else 0
                self.progress_bar.set(fraction)
                self.progress_label.configure(
                    text=f"Processing {_done} / {_total}"
                )
                self.progress_count_label.configure(
                    text=f"{int(fraction * 100)} %"
                )

            self.after(0, _ui_update)

        def _buf(message: str):
            """Append a timestamped line to the local buffer (no after() call)."""
            ts = datetime.now().strftime("%H:%M:%S")
            log_buffer.append(f"[{ts}] {message}\n")

        conn = cursor = session = None
        try:
            conn    = connect_db1()
            cursor  = conn.cursor()
            session = requests.Session()

            for serial in serials:
                if serial in self.processed:
                    _buf(f"{serial} already processed — skipping")
                else:
                    self.processed.add(serial)
                    processed_any = True
                    # _process_fg uses _buf-style internal logging passed as callback
                    self._process_fg(serial, f, cursor, session, log_fn=_buf)

                done += 1

                # Flush every N items so the event queue never accumulates thousands of calls
                if done % self._LOG_FLUSH_EVERY == 0:
                    _flush()

            # Final flush for any remaining lines
            _flush(final=True)

            label = "Reprocess All" if advance_queue else "Reprocess Selected"
            completion_msg = f"{label} completed." if processed_any else "All items already processed."
            self.after(0, lambda m=completion_msg: (
                self.log_text.insert("end", f"[{datetime.now().strftime('%H:%M:%S')}] {m}\n"),
                self.log_text.see("end"),
            ))

            # Re-enable buttons, hide progress bar
            self.after(0, lambda: self._set_processing(False))

            if advance_queue:
                self._maybe_advance_sync_queue(f)

        except Exception as e:
            _flush(final=True)
            self.log(f"Error: {e}")
            self._show_error("Error", str(e))
            self.after(0, lambda: self._set_processing(False))
        finally:
            if session: session.close()
            if cursor:  cursor.close()
            if conn:    conn.close()

    # ─── Auto-advance sync queue (background thread, no Tkinter reads) ────────

    def _maybe_advance_sync_queue(self, f: dict):
        """
        Called from the background thread after Reprocess All finishes.

        Uses f["pool"], f["from_dt"], f["to_dt"], f["sync_queue"] — all plain
        Python values captured before the thread started — so no Tkinter widget
        is touched here.

        If a next queue exists:
          • updates the sync ComboBox (via self.after → main thread)
          • clears self.processed
          • kicks off a fresh search automatically
        """
        try:
            queue_list = fetch_sync_queue_list(f["pool"], f["from_dt"], f["to_dt"])

            valid = [
                q for q in queue_list
                if q not in ("No Data Found", "Error Loading", "Select Down", "")
            ]

            if not valid:
                self.log("No sync queues found for this pool / date range.")
                return

            current = f["sync_queue"]
            try:
                idx = valid.index(current)
            except ValueError:
                self.log(f"Queue '{current}' not in list — cannot auto-advance.")
                return

            if idx + 1 >= len(valid):
                self.log("✓ All sync queues for this pool have been processed.")
                return

            next_q = valid[idx + 1]
            self.log(f"Auto-advancing: {current} → {next_q}")

            # Build next filter snapshot (all plain values — safe from any thread)
            next_f = {**f, "sync_queue": next_q, "sync_pat": f"%{next_q}%"}

            def _advance_on_main():
                # Only these two lines touch Tkinter widgets
                self.sync.configure(values=valid)
                self.sync_var.set(next_q)
                self.processed.clear()
                # Launch the next search with the updated filter snapshot
                threading.Thread(target=self._search, args=(next_f,), daemon=True).start()

            self.after(0, _advance_on_main)

        except Exception as e:
            self.log(f"Auto-advance error: {e}")

    # ─── Order number helper ──────────────────────────────────────────────────

    def _get_order_number(self, cursor, serial: str, f: dict) -> str:
        """f = filter snapshot dict — no Tkinter reads here."""
        try:
            with open(resource_path("sql/FetchOrderBaseOnFG.sql"), "r") as fh:
                query = fh.read()
            cursor.execute(query, f["pool"], f["sync_pat"], f["from_dt"], f["to_dt"], serial)
            row = cursor.fetchone()
            return row[0] if row else ""
        except Exception as e:
            self.log(f"Order fetch error for {serial}: {e}")
            return ""

    # ─── View data ────────────────────────────────────────────────────────────

    def view_data(self):
        # Snapshot filter on the main thread before opening the window
        f = self._snapshot_filter()

        view_win = ctk.CTkToplevel(self)
        view_win.title("Processed Data View")
        view_win.geometry("1000x450")

        columns = ("Order Number", "Status", "Serial Number", "Fail Date", "Reason", "Response")
        tree = ttk.Treeview(view_win, columns=columns, show="headings")
        for col in columns:
            tree.heading(col, text=col)
            tree.column(col, anchor="center", width=150)
        tree.pack(fill="both", expand=True, padx=10, pady=10)

        # Row colour tags: green = FailDictCode "", red = anything else
        style = ttk.Style(view_win)
        style.theme_use("default")
        tree.tag_configure("success", background="#1a7a3a", foreground="white")
        tree.tag_configure("failed",  background="#8b1a1a", foreground="white")
        tree.tag_configure("pending", background="#2b2b2b", foreground="#aaaaaa")

        # Snapshot tree rows on the main thread
        rows_snapshot = [
            self.tree.item(i, "values") for i in self.tree.get_children()
        ]

        conn = cursor = None
        try:
            conn = connect_db1()
            cursor = conn.cursor()

            for values in rows_snapshot:
                serial, fail_dt, reason = values[0], values[1], values[2]
                order_no = self._get_order_number(cursor, serial, f)
                result   = self.result_data.get(serial, {})
                tag      = result.get("tag", "pending")
                tree.insert("", "end", values=(
                    order_no,
                    result.get("status", "Not Processed"),
                    serial, fail_dt, reason,
                    result.get("response", ""),
                ), tags=(tag,))
        except Exception as e:
            messagebox.showerror("Error", str(e))
        finally:
            if cursor: cursor.close()
            if conn:   conn.close()

    # ─── Export Excel ─────────────────────────────────────────────────────────

    def export_excel(self):
        file = filedialog.asksaveasfilename(defaultextension=".xlsx")
        if not file:
            return

        # Snapshot both filter and tree rows on the main thread
        f = self._snapshot_filter()
        rows_snapshot = [
            self.tree.item(i, "values") for i in self.tree.get_children()
        ]

        conn = cursor = None
        try:
            conn = connect_db1()
            cursor = conn.cursor()
            export_data = []

            for values in rows_snapshot:
                serial, fail_dt, reason = values[0], values[1], values[2]
                order_no = self._get_order_number(cursor, serial, f)
                result = self.result_data.get(serial, {})
                export_data.append({
                    "Order Number": order_no,
                    "Status": result.get("status", "Not Processed"),
                    "Serial Number": serial,
                    "Fail Date": fail_dt,
                    "Reason": reason,
                    "Response": result.get("response", ""),
                })

            if not export_data:
                messagebox.showwarning("Warning", "No data to export.")
                return

            pd.DataFrame(export_data).to_excel(file, index=False)
            messagebox.showinfo("Success", f"Excel exported:\n{file}")

        except Exception as e:
            messagebox.showerror("Error", str(e))
        finally:
            if cursor: cursor.close()
            if conn:   conn.close()

