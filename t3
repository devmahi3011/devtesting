_DB_CONNECT_TIMEOUT_SEC = 10   # FIX 8
_DB_QUERY_TIMEOUT_SEC   = 30   # FIX 8


def _open_connection() -> pyodbc.Connection:
    conn_str = (
        f"DRIVER={{{os.getenv('DB2_DRIVER')}}};"
        f"SERVER={os.getenv('DB2_SERVER')};"
        f"DATABASE={os.getenv('DB2_DATABASE')};"
        f"Trusted_Connection={os.getenv('DB2_TRUSTED')};"
        f"Connection Timeout={_DB_CONNECT_TIMEOUT_SEC};"   # FIX 8
    )
    conn = pyodbc.connect(conn_str, timeout=_DB_CONNECT_TIMEOUT_SEC)
    conn.timeout = _DB_QUERY_TIMEOUT_SEC                   # FIX 8
    return conn


class ConnectionPool:
    POOL_SIZE = 4

    def __init__(self) -> None:
        self._lock  = threading.Lock()
        self._idle: list[pyodbc.Connection] = []
        self._all:  set[pyodbc.Connection]  = set()        # FIX 3 – set, not list

    def acquire(self) -> pyodbc.Connection:
        with self._lock:
            while self._idle:
                conn = self._idle.pop()
                try:
                    conn.cursor().close()   # liveness probe (local only)
                    return conn
                except Exception:
                    self._all.discard(conn)  # FIX 3 – .discard() now works
            conn = _open_connection()
            self._all.add(conn)
            log.debug("New DB connection opened (pool size=%d)", len(self._all))
            return conn

    def release(self, conn: Optional[pyodbc.Connection]) -> None:
        if conn is None:
            return
        with self._lock:
            if len(self._idle) < self.POOL_SIZE:
                try:
                    conn.rollback()
                    self._idle.append(conn)
                    return
                except Exception:
                    self._all.discard(conn)
            try:
                conn.close()
            except Exception:
                pass
            self._all.discard(conn)

    def close_all(self) -> None:
        with self._lock:
            for conn in list(self._all):
                try:
                    conn.close()
                except Exception:
                    pass
            self._idle.clear()
            self._all.clear()
        log.info("Connection pool closed.")


_POOL = ConnectionPool()


