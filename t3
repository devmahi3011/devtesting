def _resource_path(relative: str) -> Path:
    base = getattr(sys, "_MEIPASS", None) or os.path.abspath(".")
    return Path(base) / relative


class SqlCache:
    """Loads SQL files exactly once; raises FileNotFoundError early."""

    _cache: dict[str, str] = {}
    _lock = threading.Lock()

    _SQL_FILES = {
        "pool_list":        "sql/PoolList.sql",
        "sync_queue_list":  "sql/PROD_SQ.sql",
        "failed_fg":        "sql/FailedFG.sql",
        "fg_based":         "sql/AIOT03_BasedOnFG.sql",
        "order_by_fg":      "sql/FetchOrderBaseOnFG.sql",
    }

    @classmethod
    def preload(cls) -> None:
        """Call once at startup. Raises if any SQL file is missing."""
        with cls._lock:
            for key, rel_path in cls._SQL_FILES.items():
                p = _resource_path(rel_path)
                if not p.exists():
                    raise FileNotFoundError(f"SQL file missing: {p}")
                cls._cache[key] = p.read_text(encoding="utf-8")
                log.debug("SQL loaded: %s (%d chars)", key, len(cls._cache[key]))

    @classmethod
    def get(cls, key: str) -> str:
        try:
            return cls._cache[key]
        except KeyError:
            raise KeyError(f"SQL key '{key}' not found. Did you call SqlCache.preload()?")


