class DateTimePicker(ctk.CTkFrame):
    def __init__(self, master, label: str, default_time=("00", "00", "00")):
        super().__init__(master)

        ctk.CTkLabel(self, text=label, width=80).pack(side="left", padx=5)

        self.date = DateEntry(self, width=12, date_pattern="yyyy-mm-dd")
        self.date.pack(side="left", padx=5)

        self.hour = ctk.CTkComboBox(self, width=60, values=[f"{i:02d}" for i in range(24)])
        self.hour.set(default_time[0])
        self.hour.pack(side="left", padx=(10, 2))

        ctk.CTkLabel(self, text=":").pack(side="left")

        self.minute = ctk.CTkComboBox(self, width=60, values=[f"{i:02d}" for i in range(60)])
        self.minute.set(default_time[1])
        self.minute.pack(side="left", padx=2)

        ctk.CTkLabel(self, text=":").pack(side="left")

        self.second = ctk.CTkComboBox(self, width=60, values=[f"{i:02d}" for i in range(60)])
        self.second.set(default_time[2])
        self.second.pack(side="left", padx=2)

        ctk.CTkLabel(self, text="(CET)", text_color="gray").pack(side="left", padx=10)

    def get_cet_datetime(self) -> Optional[datetime]:
        """Return a CET-aware datetime, or None on parse error."""
        try:
            dt = datetime.strptime(
                f"{self.date.get()} {self.hour.get()}:{self.minute.get()}:{self.second.get()}",
                "%Y-%m-%d %H:%M:%S",
            )
            cet = pytz.timezone("Europe/Berlin")
            return cet.localize(dt, is_dst=False)
        except Exception:
            log.exception("DateTimePicker.get_cet_datetime failed")
            return None


