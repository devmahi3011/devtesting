class ValidationError(Exception):
    pass


def validate_filters(f: dict) -> None:
    """FIX 6 – Raise ValidationError with a user-friendly message if inputs are bad."""
    _INVALID_POOL  = {"", "Select Pool", "Loading…", "No pools found", None}
    _INVALID_QUEUE = {"", "Select Down", "No Data Found", "Error Loading", None}

    if f.get("pool") in _INVALID_POOL:
        raise ValidationError("Please select a valid Pool before searching.")

    if f.get("from_dt") is None:
        raise ValidationError("From Date/Time is invalid. Check the date and time fields.")

    if f.get("to_dt") is None:
        raise ValidationError("To Date/Time is invalid. Check the date and time fields.")

    if f["from_dt"] >= f["to_dt"]:
        raise ValidationError("From Date/Time must be earlier than To Date/Time.")


def validate_filters_with_queue(f: dict) -> None:
    """Same as validate_filters but also checks sync queue selection."""
    _INVALID_QUEUE = {"", "Select Down", "No Data Found", "Error Loading", None}
    validate_filters(f)
    if f.get("sync_queue") in _INVALID_QUEUE:
        raise ValidationError("Please select a valid Synchronization Queue.")


