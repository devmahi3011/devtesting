# FIX 2 + 9 – API Service  (retry/backoff + auth + SSL verify)
# ─────────────────────────────────────────────────────────────────────────────

class ApiService:
    """Handles all HTTP calls to the web-service endpoint."""

    _MAX_ATTEMPTS   = 3
    _WAIT_MIN_SEC   = 1
    _WAIT_MAX_SEC   = 8
    _REQUEST_TIMEOUT = 30

    def __init__(self, base_url: str, token: str) -> None:
        self._base_url = base_url
        self._session  = requests.Session()
        # FIX 9 – add auth header; keep SSL verification ON
        if token:
            self._session.headers.update({"Authorization": f"Bearer {token}"})
        # verify=True is the default; we do NOT pass verify=False

    # FIX 2 – retry decorator applied to the raw post
    @retry(
        retry=retry_if_exception_type((requests.Timeout, requests.ConnectionError)),
        stop=stop_after_attempt(_MAX_ATTEMPTS),
        wait=wait_exponential(multiplier=1, min=_WAIT_MIN_SEC, max=_WAIT_MAX_SEC),
        before_sleep=before_sleep_log(log, logging.WARNING),
        reraise=True,
    )
    def _post(self, payload: dict) -> requests.Response:
        return self._session.post(
            self._base_url,
            json=payload,
            timeout=self._REQUEST_TIMEOUT,
            # verify=True  ← default; do NOT disable
        )

    def send_message(self, msg: str) -> dict:
        """
        Send one message to the web service.
        Returns {"status": "Success"|"Failed"|"Error", "response": str}.
        """
        payload = {
            "Inputs":          {"IncomingMessage": msg},
            "ExecutionMode":   1,
            "Retries":         1,
            "SleepTime":       100,
            "SynchronousQueue":"",
            "Timeout":         100,
        }
        try:
            response  = self._post(payload)
            resp_json = response.json() if response.content else {}
        except requests.RequestException as exc:
            log.error("API request failed after retries: %s", exc)
            return {"status": "Error", "response": str(exc)}

        if response.status_code in (200, 201):
            fail_code = resp_json.get("FailDictCode") if isinstance(resp_json, dict) else None
            if fail_code == "":
                return {"status": "Success", "response": str(resp_json)}
            else:
                code_display = fail_code if fail_code is not None else "key missing"
                log.warning("FailDictCode=%s", code_display)
                return {"status": "Failed", "response": str(resp_json)}
        else:
            log.warning("HTTP %s from API", response.status_code)
            return {
                "status":   "Failed",
                "response": f"HTTP {response.status_code} | {resp_json}",
            }

    def close(self) -> None:
        self._session.close()


# ─────────────────────────────────────────────────────────────────────────────
# FIX 7 – Reprocess Service  (orchestration, no Tkinter)
# ─────────────────────────────────────────────────────────────────────────────

class ReprocessService:
    """
    Orchestrates the reprocess workflow.
    Completely decoupled from Tkinter — communicates via callbacks.
    """

    _LOG_FLUSH_EVERY = 10

    def __init__(
        self,
        repo: ArRepository,
        api:  ApiService,
    ) -> None:
        self._repo = repo
        self._api  = api

    def process_batch(
        self,
        serials:        list[str],
        filters:        dict,
        already_done:   set[str],
        on_log:         callable,          # (msg: str) → None
        on_progress:    callable,          # (done: int, total: int) → None
        on_result:      callable,          # (serial, result_dict) → None
        on_complete:    callable,          # () → None
    ) -> None:
        """Run in a background thread."""
        total = len(serials)
        done  = 0

        conn = cursor = None
        try:
            conn   = _POOL.acquire()
            cursor = conn.cursor()

            for serial in serials:
                if serial in already_done:
                    on_log(f"{serial} already processed — skipping")
                else:
                    already_done.add(serial)
                    self._process_one(serial, filters, cursor, on_log, on_result)

                done += 1
                on_progress(done, total)

        except Exception:
            log.exception("Batch processing error")
            on_log("Batch error — see arm.log for details")
        finally:
            if cursor:
                try: cursor.close()
                except: pass
            _POOL.release(conn)

        on_complete()

    def _process_one(
        self,
        serial:    str,
        f:         dict,
        cursor:    pyodbc.Cursor,
        on_log:    callable,
        on_result: callable,
    ) -> None:
        on_log(f"Processing: {serial}")
        try:
            messages = self._repo.fetch_fg_messages(
                cursor, f["pool"], f["sync_pat"], f["from_dt"], f["to_dt"], serial
            )
        except Exception:
            log.exception("fetch_fg_messages failed for %s", serial)
            on_log(f"DB error for {serial} — see arm.log")
            return

        if not messages:
            on_log(f"No messages found for {serial}")
            return

        success = fail = 0
        for msg in messages:
            result = self._api.send_message(msg)
            if result["status"] == "Success":
                success += 1
            else:
                fail += 1
            on_result(serial, {**result, "tag": "success" if result["status"] == "Success" else "failed"})

        on_log(f"{serial} done — Success: {success}, Failed: {fail}")


