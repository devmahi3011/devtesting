    def _wire_callbacks(self) -> None:
        self.pool_var.trace_add("write", lambda *_: self._schedule_sync_refresh())
        self.from_dt.date.bind("<<DateEntrySelected>>", lambda _e: self._schedule_sync_refresh())
        self.to_dt.date.bind("<<DateEntrySelected>>",   lambda _e: self._schedule_sync_refresh())
        for picker in (self.from_dt, self.to_dt):
            picker.hour.configure(  command=lambda v=None: self._schedule_sync_refresh())
            picker.minute.configure(command=lambda v=None: self._schedule_sync_refresh())
            picker.second.configure(command=lambda v=None: self._schedule_sync_refresh())

    # ─── Async pool loader ────────────────────────────────────────────────────

    def _load_pool_list_async(self) -> None:
        values = self._repo.fetch_pool_list()
        def _populate():
            if values:
                self.pool.configure(values=values, state="normal")
                self.pool.set(values[0])
                self.pool_var.set(values[0])
            else:
                self.pool.configure(values=["No pools found"], state="normal")
                self.pool.set("No pools found")
        self.after(0, _populate)

    # ─── Debounced sync-queue refresh ────────────────────────────────────────

    def _schedule_sync_refresh(self) -> None:
        if self._sync_refresh_job is not None:
            self.after_cancel(self._sync_refresh_job)
        self._sync_refresh_job = self.after(400, self._fire_sync_refresh)

    def _fire_sync_refresh(self) -> None:
        self._sync_refresh_job = None
        pool  = self.pool_var.get()
        f_dt  = self.from_dt.get_cet_datetime()
        t_dt  = self.to_dt.get_cet_datetime()

        _INVALID = {"", "Select Pool", "Loading…", "No pools found", None}
        if pool in _INVALID or f_dt is None or t_dt is None:
            return

        def _fetch():
            values = self._repo.fetch_sync_queue_list(pool, f_dt, t_dt)
            def _update():
                self.sync.configure(values=values)
                if values:
                    self.sync.set(values[0])
                    self.sync_var.set(values[0])
            self.after(0, _update)

        threading.Thread(target=_fetch, daemon=True).start()

    # ─── Filter snapshot (main thread) ────────────────────────────────────────

    def _snapshot_filter(self) -> dict:
        return {
            "pool":       self.pool_var.get(),
            "sync_queue": self.sync_var.get(),
            "sync_pat":   f"%{self.sync_var.get()}%",
            "from_dt":    self.from_dt.get_cet_datetime(),
            "to_dt":      self.to_dt.get_cet_datetime(),
        }

    # ─── Thread launchers ────────────────────────────────────────────────────

    def _thread_search(self) -> None:
        f = self._snapshot_filter()
        try:
            validate_filters(f)  # FIX 6
        except ValidationError as e:
            messagebox.showwarning("Validation Error", str(e))
            return
        threading.Thread(target=self._search, args=(f,), daemon=True).start()

    def _thread_reprocess_selected(self) -> None:
        selected = self.tree.selection()
        if not selected:
            messagebox.showwarning("Warning", "Select at least one Serial Number.")
            return
        f = self._snapshot_filter()
        try:
            validate_filters_with_queue(f)  # FIX 6
        except ValidationError as e:
            messagebox.showwarning("Validation Error", str(e))
            return
        serials = [self.tree.item(i, "values")[0] for i in selected]
        self._set_processing(True, total=len(serials))
        threading.Thread(
            target=self._run_reprocess, args=(serials, f, False), daemon=True
        ).start()

    def _thread_reprocess_all(self) -> None:
        serials = [self.tree.item(i, "values")[0] for i in self.tree.get_children()]
        if not serials:
            messagebox.showwarning("Warning", "No records to reprocess.")
            return
        f = self._snapshot_filter()
        try:
            validate_filters_with_queue(f)  # FIX 6
        except ValidationError as e:
            messagebox.showwarning("Validation Error", str(e))
            return
        self._set_processing(True, total=len(serials))
        threading.Thread(
            target=self._run_reprocess, args=(serials, f, True), daemon=True
        ).start()

    # FIX 10 – view_data and export run on background threads
    def _thread_view_data(self) -> None:
        f = self._snapshot_filter()
        rows_snapshot = [self.tree.item(i, "values") for i in self.tree.get_children()]
        result_snapshot = dict(self.result_data)
        threading.Thread(
            target=self._open_view_data_window,
            args=(f, rows_snapshot, result_snapshot),
            daemon=True,
        ).start()

    def _thread_export_excel(self) -> None:
        file = filedialog.asksaveasfilename(defaultextension=".xlsx")
        if not file:
            return
        f = self._snapshot_filter()
        rows_snapshot = [self.tree.item(i, "values") for i in self.tree.get_children()]
        result_snapshot = dict(self.result_data)
        threading.Thread(
            target=self._do_export,
            args=(file, f, rows_snapshot, result_snapshot),
            daemon=True,
        ).start()

    # ─── Thread-safe UI helpers ───────────────────────────────────────────────

    def _log_ui(self, message: str) -> None:
        ts   = datetime.now().strftime("%H:%M:%S")
        line = f"[{ts}] {message}\n"
        self.after(0, lambda: (self.log_text.insert("end", line), self.log_text.see("end")))

    def _clear_log(self) -> None:
        self.after(0, lambda: self.log_text.delete("1.0", "end"))

    def _clear_tree(self) -> None:
        self.after(0, lambda: [self.tree.delete(i) for i in self.tree.get_children()])

    # ─── Processing state ────────────────────────────────────────────────────

    def _set_processing(self, active: bool, total: int = 0) -> None:
        btns = (self.btn_reprocess_selected, self.btn_reprocess_all,
                self.btn_view, self.btn_export)
        if active:
            for b in btns: b.configure(state="disabled")
            self._total_serials = total
            self.progress_bar.set(0)
            self.progress_label.configure(text=f"Processing 0 / {total}")
            self.progress_count_label.configure(text="")
            self.progress_label.pack(pady=(8, 0))
            self.progress_bar.pack(pady=(4, 0))
            self.progress_count_label.pack(pady=(2, 4))
        else:
            for b in btns: b.configure(state="normal")
            self.progress_bar.set(1)
            self.progress_label.configure(text="Done ✓")
            self.progress_count_label.configure(text="")
            self.after(3000, self._hide_progress)

    def _hide_progress(self) -> None:
        for w in (self.progress_label, self.progress_bar, self.progress_count_label):
            w.pack_forget()

    def _update_progress_ui(self, done: int, total: int) -> None:
        fraction = done / total if total else 0
        self.after(0, lambda: (
            self.progress_bar.set(fraction),
            self.progress_label.configure(text=f"Processing {done} / {total}"),
            self.progress_count_label.configure(text=f"{int(fraction * 100)} %"),
        ))

    # ─── Search ──────────────────────────────────────────────────────────────

    def _search(self, f: dict) -> None:
        self._clear_log()
        self._log_ui("Search started…")
        self._clear_tree()
        self.processed.clear()
        log.info("Search: pool=%s queue=%s from=%s to=%s",
                 f["pool"], f["sync_queue"], f["from_dt"], f["to_dt"])

        rows = self._repo.fetch_failed_fg(f["pool"], f["sync_pat"], f["from_dt"], f["to_dt"])

        if not rows:
            self._log_ui("No failed FG Serial Numbers found.")
            return

        def _bulk_insert(snapshot=rows):
            for row in snapshot:
                serial  = row.fgserialnumber if hasattr(row, "fgserialnumber") else row[0]
                fail_dt = row.FinishedOn     if hasattr(row, "FinishedOn")     else row[1]
                reason  = row.Info           if hasattr(row, "Info")           else row[2]
                if fail_dt:
                    fail_dt = fail_dt.strftime("%Y-%m-%d %H:%M:%S")
                self.tree.insert("", "end", values=(serial, fail_dt, reason))

        self.after(0, _bulk_insert)
        self._log_ui(f"Loaded {len(rows)} record(s).")
        log.info("Search complete: %d rows", len(rows))

    # ─── Reprocess ───────────────────────────────────────────────────────────

    def _run_reprocess(self, serials: list[str], f: dict, advance_queue: bool) -> None:
        log_buffer: list[str] = []

        def _buf(msg: str):
            ts = datetime.now().strftime("%H:%M:%S")
            log_buffer.append(f"[{ts}] {msg}\n")
            log.info(msg)
            if len(log_buffer) >= ReprocessService._LOG_FLUSH_EVERY:
                _flush()

        def _flush():
            lines = "".join(log_buffer)
            log_buffer.clear()
            if lines:
                self.after(0, lambda l=lines: (
                    self.log_text.insert("end", l),
                    self.log_text.see("end"),
                ))

        def _on_progress(done: int, total: int):
            _flush()
            self._update_progress_ui(done, total)

        def _on_result(serial: str, result: dict):
            self.result_data[serial] = result

        def _on_complete():
            _flush()
            label = "Reprocess All" if advance_queue else "Reprocess Selected"
            self._log_ui(f"{label} completed.")
            self.after(0, lambda: self._set_processing(False))
            if advance_queue:
                threading.Thread(
                    target=self._maybe_advance_sync_queue, args=(f,), daemon=True
                ).start()

        self._clear_log()
        self._svc.process_batch(
            serials, f, self.processed,
            on_log=_buf,
            on_progress=_on_progress,
            on_result=_on_result,
            on_complete=_on_complete,
        )

    # ─── Auto-advance sync queue ──────────────────────────────────────────────

    def _maybe_advance_sync_queue(self, f: dict) -> None:
        try:
            queue_list = self._repo.fetch_sync_queue_list(f["pool"], f["from_dt"], f["to_dt"])
            valid = [q for q in queue_list if q not in ("No Data Found", "Error Loading", "Select Down", "")]

            if not valid:
                self._log_ui("No sync queues found for this pool / date range.")
                return

            current = f["sync_queue"]
            try:
                idx = valid.index(current)
            except ValueError:
                self._log_ui(f"Queue '{current}' not in list — cannot auto-advance.")
                return

            if idx + 1 >= len(valid):
                self._log_ui("✓ All sync queues processed.")
                return

            next_q = valid[idx + 1]
            self._log_ui(f"Auto-advancing: {current} → {next_q}")
            next_f = {**f, "sync_queue": next_q, "sync_pat": f"%{next_q}%"}

            def _advance():
                self.sync.configure(values=valid)
                self.sync_var.set(next_q)
                self.processed.clear()
                threading.Thread(target=self._search, args=(next_f,), daemon=True).start()

            self.after(0, _advance)
        except Exception:
            log.exception("Auto-advance error")
            self._log_ui("Auto-advance error — see arm.log")

    # ─── View data (FIX 10 – background) ─────────────────────────────────────

    def _open_view_data_window(
        self,
        f: dict,
        rows_snapshot: list[tuple],
        result_snapshot: dict,
    ) -> None:
        conn = cursor = None
        rows_to_insert = []
        try:
            conn   = _POOL.acquire()
            cursor = conn.cursor()
            for values in rows_snapshot:
                serial, fail_dt, reason = values[0], values[1], values[2]
                order_no = self._repo.fetch_order_number(
                    cursor, f["pool"], f["sync_pat"], f["from_dt"], f["to_dt"], serial
                )
                result = result_snapshot.get(serial, {})
                rows_to_insert.append((
                    order_no,
                    result.get("status", "Not Processed"),
                    serial, fail_dt, reason,
                    result.get("response", ""),
                    result.get("tag", "pending"),
                ))
        except Exception:
            log.exception("view_data query failed")
            self.after(0, lambda: messagebox.showerror("Error", "Failed to load data. See arm.log."))
            return
        finally:
            if cursor:
                try: cursor.close()
                except: pass
            _POOL.release(conn)

        def _render():
            view_win = ctk.CTkToplevel(self)
            view_win.title("Processed Data View")
            view_win.geometry("1000x450")

            columns = ("Order Number", "Status", "Serial Number", "Fail Date", "Reason", "Response")
            tree = ttk.Treeview(view_win, columns=columns, show="headings")
            for col in columns:
                tree.heading(col, text=col)
                tree.column(col, anchor="center", width=150)
            tree.pack(fill="both", expand=True, padx=10, pady=10)

            style = ttk.Style(view_win)
            style.theme_use("default")
            tree.tag_configure("success", background="#1a7a3a", foreground="white")
            tree.tag_configure("failed",  background="#8b1a1a", foreground="white")
            tree.tag_configure("pending", background="#2b2b2b", foreground="#aaaaaa")

            for row in rows_to_insert:
                *vals, tag = row
                tree.insert("", "end", values=vals, tags=(tag,))

        self.after(0, _render)

    # ─── Export Excel (FIX 10 – background) ──────────────────────────────────

    def _do_export(
        self,
        file: str,
        f: dict,
        rows_snapshot: list[tuple],
        result_snapshot: dict,
    ) -> None:
        conn = cursor = None
        export_data = []
        try:
            conn   = _POOL.acquire()
            cursor = conn.cursor()
            for values in rows_snapshot:
                serial, fail_dt, reason = values[0], values[1], values[2]
                order_no = self._repo.fetch_order_number(
                    cursor, f["pool"], f["sync_pat"], f["from_dt"], f["to_dt"], serial
                )
                result = result_snapshot.get(serial, {})
                export_data.append({
                    "Order Number":  order_no,
                    "Status":        result.get("status", "Not Processed"),
                    "Serial Number": serial,
                    "Fail Date":     fail_dt,
                    "Reason":        reason,
                    "Response":      result.get("response", ""),
                })
        except Exception:
            log.exception("export_excel query failed")
            self.after(0, lambda: messagebox.showerror("Error", "Export failed. See arm.log."))
            return
        finally:
            if cursor:
                try: cursor.close()
                except: pass
            _POOL.release(conn)

        if not export_data:
            self.after(0, lambda: messagebox.showwarning("Warning", "No data to export."))
            return

        try:
            pd.DataFrame(export_data).to_excel(file, index=False)
            log.info("Excel exported: %s", file)
            self.after(0, lambda: messagebox.showinfo("Success", f"Excel exported:\n{file}"))
        except Exception:
            log.exception("Excel write failed")
            self.after(0, lambda: messagebox.showerror("Error", "Could not write Excel file."))

    # ─── Logout ───────────────────────────────────────────────────────────────

    def _logout(self) -> None:
        self._api.close()
        _POOL.close_all()
        self.destroy()
        from login import LoginApp
        LoginApp().mainloop()


