class ArRepository:
    """Thin data-access layer. Never touches Tkinter."""

    # ── helpers ──────────────────────────────────────────────────────────────

    @staticmethod
    def _exec(cursor: pyodbc.Cursor, key: str, *params):
        """Execute a cached SQL statement with the global query timeout."""
        cursor.execute(SqlCache.get(key), *params)

    # ── public methods ───────────────────────────────────────────────────────

    def fetch_pool_list(self) -> list[str]:
        conn = None
        try:
            conn = _POOL.acquire()
            df = pd.read_sql(
                "SELECT Name FROM JOB_POOL WHERE Name LIKE '%MI%'", conn
            )
            return df["Name"].dropna().tolist()
        except Exception:
            log.exception("fetch_pool_list failed")
            return []
        finally:
            _POOL.release(conn)

    def fetch_sync_queue_list(
        self, pool: str, from_dt: datetime, to_dt: datetime
    ) -> list[str]:
        conn = cursor = None
        try:
            conn   = _POOL.acquire()
            cursor = conn.cursor()
            self._exec(cursor, "sync_queue_list", pool, from_dt, to_dt)
            rows = cursor.fetchall()
            return [r[0] for r in rows] if rows else ["No Data Found"]
        except Exception:
            log.exception("fetch_sync_queue_list failed")
            return ["Error Loading"]
        finally:
            if cursor:
                try: cursor.close()
                except: pass
            _POOL.release(conn)

    def fetch_failed_fg(
        self, pool: str, sync_pat: str, from_dt: datetime, to_dt: datetime
    ) -> list[tuple]:
        conn = cursor = None
        try:
            conn   = _POOL.acquire()
            cursor = conn.cursor()
            self._exec(cursor, "failed_fg", pool, sync_pat, from_dt, to_dt)
            return cursor.fetchall()
        except Exception:
            log.exception("fetch_failed_fg failed")
            return []
        finally:
            if cursor:
                try: cursor.close()
                except: pass
            _POOL.release(conn)

    def fetch_fg_messages(
        self,
        cursor: pyodbc.Cursor,
        pool: str,
        sync_pat: str,
        from_dt: datetime,
        to_dt: datetime,
        fgsn: str,
    ) -> list[str]:
        self._exec(cursor, "fg_based", pool, sync_pat, from_dt, to_dt, fgsn)
        rows = cursor.fetchall()
        return [r[0] for r in rows]

    def fetch_order_number(
        self,
        cursor: pyodbc.Cursor,
        pool: str,
        sync_pat: str,
        from_dt: datetime,
        to_dt: datetime,
        serial: str,
    ) -> str:
        try:
            self._exec(cursor, "order_by_fg", pool, sync_pat, from_dt, to_dt, serial)
            row = cursor.fetchone()
            return row[0] if row else ""
        except Exception:
            log.exception("fetch_order_number failed for %s", serial)
            return ""


